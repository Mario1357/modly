{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "strict":            true,
    "skipLibCheck":      true,
    "outDir":            "out/builtin-extensions",
    "rootDir":           "src/areas/workflows/nodes",
    "declaration":       false,
    "sourceMap":         false,
    "esModuleInterop":   true
  },
  "include": [
    "src/areas/workflows/nodes/mesh-exporter/**/*.ts",
    "src/areas/workflows/nodes/mesh-optimizer/**/*.ts"
  ]
}
